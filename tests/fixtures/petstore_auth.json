{
  "openapi": "3.0.0",
  "info": {
    "title": "Petstore Auth API",
    "version": "v1",
    "description": "Fixture API with security schemes for testing auth extraction"
  },
  "servers": [{ "url": "https://petstore.example.com" }],
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/pets": {
      "get": {
        "summary": "List pets",
        "description": "Inherits global bearer auth (no operation-level security override)",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/pets/{petId}": {
      "get": {
        "summary": "Get pet by ID",
        "description": "Uses API key auth override instead of global bearer",
        "security": [{ "apiKeyAuth": [] }],
        "parameters": [
          {
            "name": "petId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/health": {
      "get": {
        "summary": "Health check",
        "description": "Explicitly no auth required",
        "security": [],
        "responses": { "200": { "description": "OK" } }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      },
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-KEY"
      }
    },
    "schemas": {
      "Pet": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" }
        }
      }
    }
  }
}
